# Godot 4+ specific ignores
.godot/
.godot-shop-ui-redesign-user-data/
.godot-test-user-data/
.godot-item-icons-user-data/

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Export presets (may contain local paths)
export_presets.cfg

# Temp files
*.tmp
*.tmp.*
~*.dll
tmp/
tmp_tests/
tmp_*.log
tmp_*.png

# Local source-art exploration candidates
assets/source/intro/reference/candidates/*.png
assets/source/intro/reference/tavern_continuity_master-v*.png

# Python (asset-pipeline tooling cache)
__pycache__/
*.pyc

# Environment variables & secrets
.env

# MCP config (contains local machine-specific settings)
.mcp.json

# CodeBuddy Code (local IDE settings, AI-only)
.codebuddy/
CODEBUDDY.md

# Claude Code (AI-only, local)
CLAUDE.md
AGENTS.md

# Codex/OpenAI agents (AI-only, local)
AGENTS.md
.codex/
.worktrees/

# VS Code (keep shared settings, ignore local)
.vscode/
!.vscode/settings.json

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Windows
*.lnk

# Superpowers docs (local only)
.superpowers/
docs/superpowers/

#godot import
*.import
