# Godot 4+ specific ignores
.godot/

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Export presets (may contain local paths)
export_presets.cfg

# Temp files
*.tmp
*.tmp.*
~*.dll

# Environment variables & secrets
.env

# MCP config (contains local machine-specific settings)
.mcp.json

# CodeBuddy Code (local IDE settings, AI-only)
.codebuddy/
CODEBUDDY.md

# Claude Code (AI-only, local)
CLAUDE.md

# VS Code (keep shared settings, ignore local)
.vscode/
!.vscode/settings.json

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Windows
*.lnk

# Superpowers docs (local only)
docs/superpowers/

#godot import
*.import