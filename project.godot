; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="tavern-manager"
run/main_scene="res://scenes/ui/TitleScreen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/game_manager.gd"
DialogueManager="*uid://c3rodes2l3gxb"
TutorialManager="*res://scripts/tutorial/tutorial_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="tavern-manager"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/godot_mcp/plugin.cfg")

[input]

inventory_toggle={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":69,"key_label":0,"unicode":101,"location":0,"echo":false,"script":null)
]
}
ledger_toggle={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194306,"physical_keycode":0,"key_label":0,"unicode":9,"location":0,"echo":false,"script":null)
]
}

[internationalization]

locale/translations_pot_files=PackedStringArray("res://dialogue/mira_day12.dialogue", "res://dialogue/mira_day4.dialogue", "res://dialogue/ryan_day1.dialogue", "res://dialogue/ryan_day2.dialogue", "res://dialogue/ryan_day3.dialogue", "res://dialogue/mira_day12.post.dialogue", "res://dialogue/mira_day12.pre.dialogue", "res://dialogue/mira_day4.post.dialogue", "res://dialogue/mira_day4.pre.dialogue", "res://dialogue/ryan_day1.post.dialogue", "res://dialogue/ryan_day1.pre.dialogue", "res://dialogue/ryan_day2.post.dialogue", "res://dialogue/ryan_day2.pre.dialogue", "res://dialogue/ryan_day3.post.dialogue", "res://dialogue/ryan_day3.pre.dialogue", "res://dialogue/toby_day6.post.dialogue", "res://dialogue/toby_day6.pre.dialogue", "res://dialogue/ryan_action_feedback.dialogue")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
